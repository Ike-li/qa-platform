# Minimal sandbox image for isolated test execution.
# Dependencies come from the mounted venv, not this image.
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pytest pytest-allure-adapter

RUN useradd -m sandbox
WORKDIR /workspace
USER sandbox

# No secrets, minimal attack surface
