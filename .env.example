# ============================================================
# QA Platform - Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# --- Flask ---
FLASK_ENV=development
FLASK_APP=manage.py
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# Fernet encryption key for git credentials
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-with-cryptography

# --- MySQL ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=qaplatform
MYSQL_USER=qauser
MYSQL_PASSWORD=qapass
DATABASE_URL=mysql+pymysql://qauser:qapass@mysql:3306/qaplatform

# Test database (used when FLASK_ENV=testing)
TEST_DATABASE_URL=mysql+pymysql://qauser:qapass@mysql:3306/qaplatform_test

# --- Redis ---
# Generate a strong password: python -c "import secrets; print(secrets.token_urlsafe(24))"
REDIS_PASSWORD=change-me-to-a-strong-redis-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1

# --- Allure ---
ALLURE_REPORTS_DIR=/app/allure-reports
ALLURE_RESULTS_DIR=/app/allure-results

# --- SMTP (optional, for email notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp-password-here
SMTP_FROM=noreply@example.com

# --- Notification webhooks (optional) ---
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
